#!/usr/bin/env python3
"""A.R.I.A. local engine CLI — runs the automated pipeline stages against a
local Ollama server instead of Claude Code.

  aria-ollama check            verify the Ollama server and model are reachable
  aria-ollama triage [file]    classify inbox notes and file them
  aria-ollama develop [slug]   turn processing ideas into proposed plan drafts

Config: system/config.yml (aria.ollama.*). Env overrides: ARIA_OLLAMA_URL,
ARIA_OLLAMA_MODEL. Python 3.8+ stdlib only — nothing to pip install.

The pipeline logic lives in aria_engine.py (shared with the web UI, which
additionally streams the model's thinking live — try: aria ui).
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import aria_engine as eng  # noqa: E402


def print_event(ev):
    # tokens/prompts stream in the web UI; the CLI just prints the log lines
    if ev.get("log") and ev["event"] not in ("token", "prompt", "thinking"):
        print(ev["log"])


def check():
    h = eng.health()
    if not h["server"]:
        print(f"FAIL  cannot reach Ollama at {h['url']}: {h.get('error', '')}")
        print("      is it running? try: ollama serve")
        return 1
    print(f"ok    Ollama server at {h['url']}")
    if h["ok"]:
        print(f"ok    model {h['model']} is available")
        return 0
    print(f"FAIL  model {h['model']} not found "
          f"(have: {', '.join(h.get('models', [])) or 'none'})")
    print(f"      try: ollama pull {h['model']}")
    return 1


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else ""
    args = sys.argv[2:]
    if cmd == "triage":
        return eng.triage_run(print_event, files=args or None)
    if cmd == "develop":
        return eng.develop_run(print_event, slugs=args or None)
    if cmd == "check":
        return check()
    print(__doc__.strip())
    return 0 if cmd in ("", "-h", "--help", "help") else 1


if __name__ == "__main__":
    sys.exit(main())
