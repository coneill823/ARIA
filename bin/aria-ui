#!/usr/bin/env python3
"""A.R.I.A. web UI — a local dashboard for the pipeline that streams the
engine's thought process (prompts, tokens, decisions, file moves) live.

  aria-ui [port]     default port 8700, binds to 127.0.0.1 only

Stdlib only. Endpoints:
  GET  /              the app (ui/index.html)
  GET  /api/board     pipeline state as JSON
  GET  /api/health    Ollama reachability + model
  GET  /api/note?path=<repo-relative .md>   note content
  GET  /api/run?stage=triage|develop|auto   Server-Sent Events stream
       (&file=<inbox note> scopes triage/auto, &slug=<slug> scopes develop)
  POST /api/capture   {"text": "..."} -> new inbox note
  POST /api/refine    {"slug", "feedback"} -> idea goes back to processing
  POST /api/export    {"slug"} -> publish project into the Obsidian vault
"""

import json
import sys
import threading
import urllib.parse
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import aria_engine as eng  # noqa: E402

UI_DIR = eng.ROOT / "ui"
PAGES = {"/": UI_DIR / "index.html", "/board": UI_DIR / "board.html"}
RUN_LOCK = threading.Lock()  # one engine run at a time


class Handler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def log_message(self, fmt, *args):
        pass

    # ------------------------------------------------------------ helpers

    def send_json(self, obj, code=200):
        data = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def send_sse_headers(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "close")
        self.end_headers()

    # ------------------------------------------------------------ routes

    def do_GET(self):
        url = urllib.parse.urlparse(self.path)
        query = urllib.parse.parse_qs(url.query)

        if url.path in PAGES:
            data = PAGES[url.path].read_bytes()
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        elif url.path == "/api/board":
            self.send_json(eng.board())
        elif url.path == "/api/health":
            self.send_json(eng.health())
        elif url.path == "/api/config":
            cfg = eng.config()
            self.send_json({"obsidian_vault": cfg["obsidian_vault"],
                            "auto_pipeline": cfg["auto_pipeline"],
                            "model": cfg["model"]})
        elif url.path == "/api/note":
            rel = (query.get("path") or [""])[0]
            target = (eng.ROOT / rel).resolve()
            if (not str(target).startswith(str(eng.ROOT) + "/")
                    or target.suffix != ".md" or not target.is_file()):
                self.send_json({"error": "not found"}, 404)
                return
            self.send_json({"path": rel,
                            "content": target.read_text(encoding="utf-8")})
        elif url.path == "/api/run":
            self.run_stage((query.get("stage") or [""])[0],
                           file=(query.get("file") or [""])[0],
                           slug=(query.get("slug") or [""])[0])
        else:
            self.send_json({"error": "not found"}, 404)

    def do_POST(self):
        url = urllib.parse.urlparse(self.path)
        length = int(self.headers.get("Content-Length") or 0)
        try:
            body = json.loads(self.rfile.read(length) or b"{}")
            if url.path == "/api/capture":
                path = eng.capture_note(str(body.get("text", "")), source="ui")
                self.send_json({"ok": True, "file": path.name,
                                "path": str(path.relative_to(eng.ROOT))})
            elif url.path == "/api/refine":
                dest = eng.refine(str(body.get("slug", "")),
                                  str(body.get("feedback", "")))
                self.send_json({"ok": True, "slug": dest.stem,
                                "path": str(dest.relative_to(eng.ROOT))})
            elif url.path == "/api/export":
                index = eng.export_obsidian(str(body.get("slug", "")))
                self.send_json({"ok": True, "path": str(index)})
            elif url.path == "/api/config":
                for key in ("obsidian_vault", "auto_pipeline"):
                    if key in body:
                        eng.config_set(key, str(body[key]).strip())
                cfg = eng.config()
                self.send_json({"ok": True,
                                "obsidian_vault": cfg["obsidian_vault"],
                                "auto_pipeline": cfg["auto_pipeline"]})
            elif url.path == "/api/chat":
                self.chat(body)
            else:
                self.send_json({"error": "not found"}, 404)
        except Exception as exc:
            self.send_json({"error": str(exc)}, 400)

    # ------------------------------------------------------------ voice chat

    def chat(self, body):
        messages = body.get("messages") or []
        if not isinstance(messages, list) or not messages:
            self.send_json({"error": "messages required"}, 400)
            return
        last = str(messages[-1].get("content", ""))

        self.send_sse_headers()

        def emit(ev):
            try:
                self.wfile.write(b"data: " + json.dumps(ev).encode() + b"\n\n")
                self.wfile.flush()
            except (BrokenPipeError, ConnectionResetError):
                pass

        try:
            intent = eng.detect_intent(last)
            if intent and intent["action"] == "capture":
                path = eng.capture_note(intent["text"], source="voice")
                auto = eng.config()["auto_pipeline"]
                say = f"Captured — filed as {path.name}."
                if auto:
                    say += " Auto-pipeline is on, so I'm triaging it now."
                emit({"event": "action",
                      "action": "auto" if auto else "capture",
                      "file": path.name, "say": say})
            elif intent:
                emit({"event": "action", "action": intent["action"],
                      "say": f"On it — running {intent['action']} now."})
            else:
                eng.converse(messages,
                             on_token=lambda t: emit({"event": "token",
                                                      "text": t}))
        except Exception as exc:
            emit({"event": "error", "log": str(exc)})
        emit({"event": "done"})

    # ------------------------------------------------------------ engine

    def run_stage(self, stage, file="", slug=""):
        if stage not in ("triage", "develop", "auto"):
            self.send_json({"error": "stage must be triage, develop or auto"}, 400)
            return
        if not RUN_LOCK.acquire(blocking=False):
            self.send_json({"error": "a run is already in progress"}, 409)
            return
        try:
            self.send_sse_headers()
            dead = False

            def emit(ev):
                nonlocal dead
                if dead:
                    return  # keep the pipeline consistent even if the tab closed
                try:
                    self.wfile.write(b"data: " + json.dumps(ev).encode() + b"\n\n")
                    self.wfile.flush()
                except (BrokenPipeError, ConnectionResetError):
                    dead = True

            files = [f"pipeline/00-inbox/{Path(file).name}"] if file else None
            try:
                if stage == "triage":
                    eng.triage_run(emit, files=files)
                elif stage == "auto":
                    eng.auto_run(emit, files=files)
                else:
                    eng.develop_run(emit, slugs=[slug] if slug else None)
            except Exception as exc:
                emit({"event": "error", "log": f"engine crashed: {exc}"})
            emit({"event": "done"})
        finally:
            RUN_LOCK.release()


def main():
    port = int(sys.argv[1]) if len(sys.argv) > 1 and sys.argv[1].isdigit() else 8700
    server = ThreadingHTTPServer(("127.0.0.1", port), Handler)
    print(f"A.R.I.A. UI -> http://127.0.0.1:{port}  (Ctrl+C to stop)")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nstopped")


if __name__ == "__main__":
    main()
