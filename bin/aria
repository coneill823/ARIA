#!/usr/bin/env bash
# A.R.I.A. command-line interface.
#
#   aria capture "idea text"   instant capture to the inbox (no LLM call)
#   aria triage                classify the inbox
#   aria develop [slug]        ideas -> proposed plans
#   aria auto                  triage, then develop new projects (idea -> plan)
#   aria status                pipeline dashboard        (headless Claude Code)
#   aria ui [port]             web UI: voice orb + board (default :8700)
#   aria app [port]            open A.R.I.A. as a desktop app window
#   aria install-desktop       add A.R.I.A. to your application menu
#   aria install-skills        install Anthropic's Agent Skills for Claude Code
#   aria doctor                sanity-check the setup
#
# triage/develop/auto run on the engine set in system/config.yml (aria.engine):
# 'ollama' = your local Ollama server, 'claude' = headless Claude Code.
# Override per-run: ARIA_ENGINE=claude bin/aria triage
# Cron example:  0 7 * * *  cd /path/to/aria && bin/aria auto
set -euo pipefail

ARIA_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INBOX="$ARIA_ROOT/pipeline/00-inbox"

usage() { sed -n '2,18p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; }

engine() {
  if [ -n "${ARIA_ENGINE:-}" ]; then
    echo "$ARIA_ENGINE"
  else
    sed -n 's/^[[:space:]]*engine:[[:space:]]*\([a-z]*\).*/\1/p' \
      "$ARIA_ROOT/system/config.yml" | head -1 | grep . || echo claude
  fi
}

require_claude() {
  command -v claude >/dev/null 2>&1 || {
    echo "error: claude CLI not found — install Claude Code first" >&2
    echo "       https://code.claude.com/docs" >&2
    echo "       (or set engine: ollama in system/config.yml)" >&2
    exit 1
  }
}

cmd="${1:-}"
shift || true

case "$cmd" in
  capture)
    idea="${*:-}"
    if [ -z "$idea" ]; then
      echo "usage: aria capture \"your idea, rambling welcome\"" >&2
      exit 1
    fi
    mkdir -p "$INBOX"
    stamp_id="$(date +%Y%m%d-%H%M)"
    stamp_iso="$(date -u +%Y-%m-%dT%H:%MZ)"
    # first few words of the idea, kebab-cased, as a filename hint
    snippet="$(printf '%s' "$idea" | tr '[:upper:]' '[:lower:]' \
      | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-40 \
      | awk -F- '{print $1"-"$2"-"$3"-"$4}' | sed 's/-*$//')"
    file="$INBOX/$(date +%Y-%m-%d-%H%M)-${snippet:-idea}.md"
    if [ -e "$file" ]; then file="${file%.md}-$RANDOM.md"; fi
    cat > "$file" <<EOF
---
id: $stamp_id
captured: $stamp_iso
status: inbox
type: unclassified
slug:
source: cli
tags: []
---

## Raw capture

$idea

<!-- Sections below are added by the pipeline, never above this line. -->
EOF
    echo "captured -> ${file#"$ARIA_ROOT"/}"
    echo "run 'aria triage' (or /triage in Claude Code) to classify"
    ;;

  triage)
    if [ "$(engine)" = "ollama" ]; then
      exec "$ARIA_ROOT/bin/aria-ollama" triage "$@"
    fi
    require_claude
    cd "$ARIA_ROOT" && claude -p "/triage"
    ;;

  develop)
    if [ "$(engine)" = "ollama" ]; then
      exec "$ARIA_ROOT/bin/aria-ollama" develop "$@"
    fi
    require_claude
    cd "$ARIA_ROOT" && claude -p "/develop ${1:-}"
    ;;

  auto)
    if [ "$(engine)" = "ollama" ]; then
      exec "$ARIA_ROOT/bin/aria-ollama" auto "$@"
    fi
    require_claude
    cd "$ARIA_ROOT" && claude -p "/triage" && claude -p "/develop"
    ;;

  status)
    require_claude
    cd "$ARIA_ROOT" && claude -p "/status"
    ;;

  ui)
    exec python3 "$ARIA_ROOT/bin/aria-ui" "$@"
    ;;

  app)
    exec "$ARIA_ROOT/bin/aria-app" "$@"
    ;;

  install-desktop)
    APPS="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
    mkdir -p "$APPS" "${XDG_STATE_HOME:-$HOME/.local/state}"
    cat > "$APPS/aria.desktop" <<DESKTOP
[Desktop Entry]
Type=Application
Name=A.R.I.A.
Comment=Autonomous Reasoning & Intelligence Assistant
Exec=$ARIA_ROOT/bin/aria-app
Icon=$ARIA_ROOT/docs/aria-icon.svg
Terminal=false
Categories=Utility;Development;
StartupWMClass=ARIA
DESKTOP
    update-desktop-database "$APPS" 2>/dev/null || true
    echo "installed -> $APPS/aria.desktop"
    echo "A.R.I.A. is now in your application menu"
    ;;

  install-skills)
    exec "$ARIA_ROOT/bin/aria-install-skills"
    ;;

  doctor)
    ok=0
    for d in pipeline/00-inbox pipeline/01-processing \
             pipeline/02-potential-projects pipeline/knowledge \
             pipeline/archive system/templates .claude/commands .claude/agents; do
      if [ -d "$ARIA_ROOT/$d" ]; then echo "ok   $d"
      else echo "MISS $d"; ok=1; fi
    done
    echo "engine: $(engine)"
    if [ "$(engine)" = "ollama" ]; then
      "$ARIA_ROOT/bin/aria-ollama" check || ok=1
    fi
    command -v claude >/dev/null 2>&1 \
      && echo "ok   claude CLI ($(command -v claude))" \
      || { echo "note claude CLI missing (capture + ollama engine still work)"; }
    exit $ok
    ;;

  ""|-h|--help|help)
    usage
    ;;

  *)
    echo "error: unknown command '$cmd'" >&2
    usage >&2
    exit 1
    ;;
esac
